@model TaskItem

@section Styles {
    <link rel="stylesheet" href="~/css/custom/forms.css" asp-append-version="true" />
}

<div class="form-wrapper">
    <div class="form-container">
        <h1>Edit Task</h1>

        <form asp-action="Edit" method="post" class="task-form">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Title" class="form-label">Task Title:</label>
                <input asp-for="Title" class="form-control" placeholder="Enter task title" maxlength="30" />
                <span asp-validation-for="Title" class="text-danger"></span>
                <small class="form-help">Max 30 characters</small>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Description:</label>
                <textarea asp-for="Description" class="form-control" placeholder="Enter task description" maxlength="1000" rows="4"></textarea>
                <small class="form-help">Max 1000 characters</small>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="StartDate" class="form-label">Starting Date:</label>
                    <input asp-for="StartDate" type="datetime-local" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Deadline" class="form-label">Due Date:</label>
                    <input asp-for="Deadline" type="datetime-local" class="form-control" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Priority" class="form-label">Priority Level:</label>
                    <select asp-for="Priority" class="form-control">
                        <option value="0">High</option>
                        <option value="1">Medium</option>
                        <option value="2">Low</option>
                    </select>
                </div>
                <div class="form-group checkbox-group">
                    <label class="form-label">
                        <input asp-for="IsCompleted" type="checkbox" class="form-checkbox" />
                        <span>Mark as Completed</span>
                    </label>
                </div>
            </div>

            <div class="form-divider"></div>

            <button type="submit" class="btn btn-primary btn-lg">Save Task</button>
        </form>
    </div>

    <!-- Checklist Panel -->
    <div class="checklist-panel">
        <h2>Progress Checklist</h2>

        @if (Model.ChecklistItems.Any())
        {
            var progressPercentage = Model.GetProgressPercentage();
            var completedCount = Model.ChecklistItems.Count(c => c.IsCompleted);
            
            <div class="progress-container">
                <div class="progress-stats">
                    <span class="progress-text">@completedCount of @Model.ChecklistItems.Count items completed</span>
                    <span class="progress-percent">@progressPercentage%</span>
                </div>
                <div class="progress-bar-wrapper">
                    <div class="progress-bar" style="width: @progressPercentage%"></div>
                </div>
            </div>

            <div class="checklist-items">
                @foreach (var item in Model.ChecklistItems)
                {
                    <div class="checklist-item" data-item-id="@item.Id">
                        <input type="checkbox" class="checklist-toggle" data-item-id="@item.Id" @(item.IsCompleted ? "checked" : "") />
                        <span class="item-description @(item.IsCompleted ? "completed" : "")">@item.Description</span>
                        <button type="button" class="btn-delete-item" data-item-id="@item.Id" title="Delete">×</button>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="no-items-message">No checklist items yet. Add one below to track progress!</p>
        }

        <!-- Add Checklist Item -->
        <div class="add-item-section">
            <input type="text" id="newChecklistItem" class="form-control" placeholder="Add a new checklist item..." maxlength="200" />
            <button type="button" id="addChecklistBtn" class="btn btn-add">Add Item</button>
        </div>
    </div>
</div>

<a href="@Url.Action("Index", "Home")" class="btn btn-secondary btn-back">Back to Tasks</a>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    const MODEL_TASK_ID = @Model.Id;
    </script>
    <script src="~/js/custom/edit-task.js" asp-append-version="true"></script>
}